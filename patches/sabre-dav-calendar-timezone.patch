+
+    /**
+     * Resolve {urn:ietf:params:xml:ns:caldav}calendar-timezone to DateTimeZone.
+     *
+     * RFC 4791 defines calendar-timezone as a VCALENDAR containing a VTIMEZONE.
+     * Baikal (PDO backend) stores a plain Olson id such as "America/Toronto".
+     * Clients that request calendar-data expand (e.g. Home Assistant) previously
+     * caused Sabre\VObject\ParseException when the plain id was VObject-parsed.
+     *
+     * Accepts:
+     *  - plain timezone ids (Olson / PHP DateTimeZone names)
+     *  - iCalendar VCALENDAR/VTIMEZONE blobs
+     * Falls back to UTC if the value cannot be interpreted.
+     *
+     * @param mixed $value Property value from the calendar backend
+     *
+     * @return DateTimeZone
+     */
+    public static function resolveCalendarTimeZone($value)
+    {
+        if (!is_string($value)) {
+            if (is_object($value) && method_exists($value, '__toString')) {
+                $value = (string) $value;
+            } else {
+                return new DateTimeZone('UTC');
+            }
+        }
+
+        $trimmed = trim($value);
+        if ('' === $trimmed) {
+            return new DateTimeZone('UTC');
+        }
+
+        // Plain timezone id — no iCalendar structure (Baikal default storage).
+        if (false === stripos($trimmed, 'BEGIN:')) {
+            try {
+                return new DateTimeZone($trimmed);
+            } catch (\Exception $e) {
+                return new DateTimeZone('UTC');
+            }
+        }
+
+        // RFC 4791: VCALENDAR with a single VTIMEZONE component.
+        try {
+            $vtimezoneObj = VObject\Reader::read($trimmed);
+            if (isset($vtimezoneObj->VTIMEZONE)) {
+                $timeZone = $vtimezoneObj->VTIMEZONE->getTimeZone();
+                $vtimezoneObj->destroy();
+
+                return $timeZone;
+            }
+            $vtimezoneObj->destroy();
+        } catch (VObject\ParseException $e) {
+            // Fall through to plain-id / UTC attempts.
+        } catch (\Exception $e) {
+            // Fall through to plain-id / UTC attempts.
+        }
+
+        try {
+            return new DateTimeZone($trimmed);
+        } catch (\Exception $e) {
+            return new DateTimeZone('UTC');
+        }
+    }
 }
