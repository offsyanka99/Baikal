{
    "name": "sabre/baikal",
    "type": "project",
    "description": "Ba\u00efkal is a lightweight CalDAV + CardDAV server based on PHP, SQLite or MySQL, and SabreDAV",
    "keywords": [
        "Project",
        "Server",
        "Calendar",
        "Contact",
        "WebDAV",
        "CalDAV",
        "CardDAV",
        "iCalendar",
        "lightweight"
    ],
    "homepage": "https://sabre.io/baikal/",
    "license": "GPL-3.0-only",
    "require": {
        "php": "^8.2",
        "sabre/dav": "~4.7.0",
        "twig/twig": "~3.27.1",
        "symfony/yaml": "~7.4.8",
        "symfony/string": "^7.2",
        "ext-dom": "*",
        "ext-pdo": "*",
        "ext-zlib": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "3.89.2",
        "phpstan/phpstan": "2.1.53",
        "phpstan/phpstan-deprecation-rules": "2.0.4",
        "sebastian/diff": "^6.0"
    },
    "replace": {
        "jeromeschneider/baikal": "self.version"
    },
    "autoload": {
        "psr-0": {
            "BaikalAdmin": "Core/Frameworks/",
            "Baikal": "Core/Frameworks/",
            "Flake": "Core/Frameworks/",
            "Formal": "Core/Frameworks/"
        }
    },
    "support": {
        "source": "https://github.com/offsyanka99/Baikal",
        "docs": "https://sabre.io/baikal/"
    },
    "scripts": {
        "cs-fixer": [
            "php-cs-fixer fix"
        ],
        "phpstan": [
            "phpstan analyse Core html"
        ],
        "test": [
            "composer cs-fixer",
            "composer phpstan"
        ],
        "apply-vendor-patches": [
            "sh scripts/apply-vendor-patches.sh"
        ],
        "post-install-cmd": [
            "@apply-vendor-patches"
        ],
        "post-update-cmd": [
            "@apply-vendor-patches"
        ]
    }
}
